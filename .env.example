# Azure OpenAI
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Grafana Cloud — OTLP gateway (direct, no collector needed)
# Find this in your Grafana Cloud stack under "OpenTelemetry" → "OTLP endpoint"
# e.g. https://otlp-gateway-prod-eu-west-0.grafana.net/otlp
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-<region>.grafana.net/otlp

# Base64 of "<InstanceID>:<API_Key>" — generate with:
#   PowerShell: [Convert]::ToBase64String([Text.Encoding]::ASCII.GetBytes("123456:glc_abc..."))
#   bash:       echo -n "123456:glc_abc..." | base64
GRAFANA_CLOUD_AUTH=your-base64-instance-id-colon-api-key

# OpenTelemetry service identity
OTEL_SERVICE_NAME=cpg-supply-chain
DEPLOYMENT_ENVIRONMENT=development

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
